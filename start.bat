@echo off
chcp 65001 > NUL
title ときわ苑ショートステイ空き状況システム 起動ランチャー

echo ==========================================================
echo   ときわ苑ショートステイ空き状況システムを起動しています...
echo ==========================================================
echo.

:: 1. Excel監視スクリプトの起動（別ウィンドウ）
echo [1/2] Excelファイルの自動監視プログラムを起動しています...
start "ときわ苑ショートステイ Excel監視" python update_vacancy.py

:: 2. 簡易Webサーバーの起動（別ウィンドウ）
echo [2/2] 簡易Webサーバー (ポート 8000) を起動しています...
start "ときわ苑ショートステイ Webサーバー" python -m http.server 8000

:: 3. サーバー起動待機 (2秒) 後、ブラウザでサイトを自動表示
timeout /t 2 > NUL
echo.
echo ブラウザを起動し、カレンダー画面を表示します...
start http://localhost:8000

echo.
echo ==========================================================
echo   起動が完了しました！
echo   ※起動した黒いウィンドウ（Excel監視・Webサーバー）は
echo     閉じずにそのまま開いたままにしてください。
echo   ※この起動画面は閉じていただいて構いません。
echo ==========================================================
echo.
pause
